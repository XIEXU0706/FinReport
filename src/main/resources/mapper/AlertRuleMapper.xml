<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.finreport.module.alert.mapper.AlertRuleMapper">

    <select id="selectById" resultType="org.example.finreport.module.alert.entity.AlertRule">
        SELECT * FROM alert_rule WHERE id = #{id}
    </select>

    <select id="selectList" resultType="org.example.finreport.module.alert.entity.AlertRule">
        SELECT * FROM alert_rule
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO alert_rule (rule_name, metric, operator, threshold, severity, status, description, created_at, updated_at)
        VALUES (#{ruleName}, #{metric}, #{operator}, #{threshold}, #{severity}, #{status}, #{description}, NOW(), NOW())
    </insert>

    <update id="updateById">
        UPDATE alert_rule
        <set>
            <if test="ruleName != null">rule_name = #{ruleName},</if>
            <if test="metric != null">metric = #{metric},</if>
            <if test="operator != null">operator = #{operator},</if>
            <if test="threshold != null">threshold = #{threshold},</if>
            <if test="severity != null">severity = #{severity},</if>
            <if test="status != null">status = #{status},</if>
            <if test="description != null">description = #{description},</if>
            updated_at = NOW()
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM alert_rule WHERE id = #{id}
    </delete>

    <select id="selectPage" resultType="org.example.finreport.module.alert.entity.AlertRule">
        SELECT * FROM alert_rule ORDER BY id DESC LIMIT #{limit} OFFSET #{offset}
    </select>

    <select id="selectCount" resultType="long">
        SELECT COUNT(*) FROM alert_rule
    </select>

    <select id="selectByStatus" resultType="org.example.finreport.module.alert.entity.AlertRule">
        SELECT * FROM alert_rule WHERE status = #{status}
    </select>

</mapper>
